---
import "../styles/note.scss";
import BaseLayout from "./BaseLayout.astro";
import { getImage } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  note: CollectionEntry<"notes">;
}

const { note } = Astro.props;
const {
  title,
  subline,
  image,
  coverImage,
  publishedAt,
  updatedAt,
  role,
  timeline,
  areas,
} = note.data;

const heroDesktop = await getImage({ src: coverImage ?? image, alt: title });
const heroMobile = image
  ? await getImage({ src: image, alt: title })
  : heroDesktop;

const formatted = (d: Date) =>
  d.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
---

<BaseLayout title={title}>
  <!-- Hero image -->
  <section class="note-hero" data-animate style="--delay: 0">
    <picture>
      <source media="(min-width: 769px)" srcset={heroDesktop.src} />
      <img
        src={heroMobile.src}
        alt={title}
        class="note-hero__image"
        loading="eager"
        width={heroMobile.options.width as number | undefined}
        height={heroMobile.options.height as number | undefined}
      />
    </picture>
  </section>

  <!-- Header -->
  <section class="reset-p-bottom">
    <div class="inner inner--note-header">
      <!-- <p class="note-meta" data-animate style="--delay: 1">
        {formatted(publishedAt)}
        {
          updatedAt && (
            <span class="note-meta__updated">
              {" "}
              · Updated {formatted(updatedAt)}
            </span>
          )
        }
      </p> -->
      <h1 class="display" data-animate style="--delay: 2">{title}</h1>

      {
        (timeline || role || areas) && (
          <div class="note-info-grid" data-animate style="--delay: 3">
            {timeline && (
              <div class="note-info timeline">
                <p class="caption">Timeline</p>
                <p class="value">{timeline}</p>
              </div>
            )}
            {role && (
              <div class="note-info role">
                <p class="caption">My Role</p>
                <p class="value" set:html={role} />
              </div>
            )}
            {areas && (
              <div class="note-info areas">
                <p class="caption">Focus</p>
                <p class="value" set:html={areas} />
              </div>
            )}
          </div>
        )
      }
    </div>
  </section>

  <!-- Body -->
  <section>
    <div class="inner inner--note-body">
      <div class="note-body">
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>
