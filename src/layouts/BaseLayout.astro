---
import "@styles/index.scss";
import "@fontsource-variable/figtree/wght.css";
import "@fontsource-variable/figtree/wght-italic.css";
import "@fontsource/instrument-serif/400.css";
import "@fontsource/instrument-serif/400-italic.css";
import "@fontsource/libertinus-serif/400.css";
import * as content from "@consts";
import Navigation from "@components/Navigation/Navigation.astro";
import Footer from "@components/Footer/Footer.astro";
import { ClientRouter } from "astro:transitions";
import Cursor from "@components/Cursor/Cursor.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!-- 
Hey! You're looking at the source. Nice. 
Want to chat about how this was built? 
Reach out: hey@markus.design 
-->
<html
  lang="en"
  data-theme="dark"
  data-cursor-default={content.cursorVisibleByDefault ? "visible" : "hidden"}
>
  <head>
    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="5847c055-cf5a-48d3-9f11-9934183acd3e"></script>
    <script is:inline>
      // Apply saved theme immediately — before paint — to avoid flash.
      const saved = localStorage.getItem("theme");
      if (saved) document.documentElement.dataset.theme = saved;
      // Only manage cursor-hidden state when cursor is opt-in (not visible by default).
      if (
        document.documentElement.dataset.cursorDefault === "hidden" &&
        localStorage.getItem("cursor-hidden") !== "0"
      )
        document.documentElement.setAttribute("data-cursor-hidden", "");
    </script>

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Markus Kammin",
        "jobTitle": "Head of UX",
        "url": "https://markus.design",
        "image": {
          "@type": "ImageObject",
          "url": "https://markus.design/me.jpg",
          "width": 800,
          "height": 800
        },
        "sameAs": [
          "https://www.linkedin.com/in/markuskammin/",
          "https://github.com/mrkskmn"
        ],
        "worksFor": {
          "@type": "Organization",
          "name": "Haiilo",
          "url": "https://www.haiilo.com"
        },
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Hamburg",
          "addressCountry": "DE"
        }
      }
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://open.spotify.com" /><link
      rel="dns-prefetch"
      href="https://i.scdn.co"
    />
    <link
      rel="canonical"
      href={new URL(Astro.url.pathname, "https://markus.design").href}
    />

    <!-- Primary Meta tags -->
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1"
      viewport-fit="content"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={content.description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={`Markus Kammin | ${title}`} />
    <meta property="og:description" content={content.description} />
    <meta property="og:image" content={content.ogImage} />
    <meta property="og:type" content="website" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`Markus Kammin | ${title}`} />
    <meta name="twitter:description" content={content.description} />
    <meta name="twitter:image" content={content.ogImage} />

    <title>Markus Kammin | {title}</title>
    <ClientRouter />
    <style lang="scss" is:global>
      @use "styles/tokens" as tokens;

      @keyframes blur-out {
        from {
          filter: blur(0);
          opacity: 1;
        }
        to {
          filter: blur(1rem);
          opacity: 0;
        }
      }

      @keyframes blur-in {
        from {
          filter: blur(1rem);
          opacity: 0;
        }
        to {
          filter: blur(0);
          opacity: 1;
        }
      }

      ::view-transition-old(root) {
        animation: blur-out tokens.duration(slow) tokens.easing(default)
          forwards;
      }

      ::view-transition-new(root) {
        animation: blur-in tokens.duration(slow) tokens.easing(default) forwards;
      }
    </style>
  </head><body>
    <Navigation />
    <Cursor
      labels={["Visitor", "You", "Curious goose", "Goose on the loose"]}
      pageLabels={[
        {
          path: "/notes/",
          labels: [
            "Reading goose",
            "Deep in the notes",
            "Studious goose",
            "Portfolio goose",
          ],
        },
        {
          path: "/notes",
          labels: [
            "Browsing goose",
            "Picking a read",
            "Curious goose",
            "Portfolio goose",
          ],
        },
      ]}
      timeLabels={[
        { from: 22, to: 4, labels: ["Night owl", "Sleepy goose"] },
        { from: 5, to: 8, labels: ["Early bird", "Morning goose"] },
      ]}
    />

    <slot />

    <Footer />
  </body><script>
    function initScrollAnimations() {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target); // animate once
            }
          });
        },
        { threshold: 0.35 },
      );

      document
        .querySelectorAll("[data-animate-scroll]")
        .forEach((el) => observer.observe(el));
    }

    // Runs on initial load and after every page transition
    document.addEventListener("astro:page-load", initScrollAnimations);

    // Re-apply saved theme to the incoming document before the swap animation
    // plays — prevents a flash of the default "light" theme during navigation.
    import type { TransitionBeforeSwapEvent } from "astro:transitions/client";
    document.addEventListener("astro:before-swap", (e) => {
      const saved = localStorage.getItem("theme");
      if (saved)
        (
          e as TransitionBeforeSwapEvent
        ).newDocument.documentElement.dataset.theme = saved;
      if (
        e.newDocument.documentElement.dataset.cursorDefault === "hidden" &&
        localStorage.getItem("cursor-hidden") !== "0"
      )
        (
          e as TransitionBeforeSwapEvent
        ).newDocument.documentElement.setAttribute("data-cursor-hidden", "");
    });
  </script>
</html>
