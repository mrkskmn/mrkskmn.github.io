---
import "./Footer.scss";
import * as content from "@consts";

const year = new Date().getFullYear();

const spotifyTracks = [
  "https://open.spotify.com/embed/track/5Yu1hJpkMPMiNn3Ymh4a3c",
  "https://open.spotify.com/embed/track/1x6wjqiZIx47WgVrCY15k2",
  "https://open.spotify.com/embed/track/5wMhlHcon8U2WNA05QMUb6",
];
---

<footer class="footer" data-animate-scroll style="--delay:1">
  <div class="footer__inner">
    <div class="footer__grid">
      <!-- on repeat -->
      <div class="footer__col footer__col--spotify">
        <h3 class="footer__heading">on repeat.</h3>
        <iframe
          title="One of my current favourite tracks on Spotify"
          id="spotify-embed"
          class="footer__spotify"
          src={spotifyTracks[0]}
          data-tracks={JSON.stringify(spotifyTracks)}
          width="100%"
          height="152"
          frameborder="0"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"></iframe>
      </div>

      <!-- spacer -->
      <div class="footer__col footer__col--empty"></div>

      <!-- links -->
      <div class="footer__col">
        <p class="footer__col-title">All the links</p>
        <nav class="footer__nav stack stack--v gap--lg">
          <a href="/">{content.home}</a>
          {content.activateCases && <a href="/notes">{content.notes}</a>}
          {
            content.activateCV && (
              <a href={content.cvURL} target="_blank">
                {content.cv}
              </a>
            )
          }
        </nav>
      </div>

      <!-- contacts -->
      <div class="footer__col">
        <p class="footer__col-title">All the contacts</p>
        <div class="footer__nav stack stack--v gap--lg">
          <a
            href="https://www.linkedin.com/in/markuskammin/"
            target="_blank"
            rel="noopener noreferrer">{content.linkedin}</a
          >
          <a
            href="https://github.com/mrkskmn"
            target="_blank"
            rel="noopener noreferrer">{content.github}</a
          >
          <a href="mailto:hey@markus.design">{content.contact}</a>
        </div>
      </div>
    </div>

    <p class="footer__subline">
      <span>&copy; 2025 &ndash; {year}</span>
      &middot;
      <a href="/imprint">{content.imprint}</a>
    </p>
  </div>
</footer>

<script>
  function randomiseSpotify() {
    const iframe = document.getElementById(
      "spotify-embed",
    ) as HTMLIFrameElement;
    if (!iframe) return;
    const tracks: string[] = JSON.parse(iframe.dataset.tracks ?? "[]");
    if (!tracks.length) return;
    const pick = tracks[Math.floor(Math.random() * tracks.length)];
    iframe.src = pick;
  }

  // Run on initial load and after every client-side navigation
  document.addEventListener("astro:page-load", randomiseSpotify);

  // Detect Spotify play/pause via postMessage and bubble as custom events
  let wasPlaying = false;
  window.addEventListener("message", (e) => {
    if (e.origin !== "https://open.spotify.com") return;
    try {
      const data = e.data;
      if (data.type !== "playback_update") return;
      const playing = !data.payload.isPaused;
      if (playing === wasPlaying) return; // no state change, ignore
      wasPlaying = playing;
      window.dispatchEvent(
        new CustomEvent(playing ? "spotify:play" : "spotify:pause"),
      );
    } catch {}
  });
</script>
