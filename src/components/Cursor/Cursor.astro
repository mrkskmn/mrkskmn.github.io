---
interface Props {
  label?: string;
  labels?: string[];
  pageLabels?: { path: string; labels: string[] }[];
  timeLabels?: { from: number; to: number; labels: string[] }[];  // from/to: 0–23, wraps midnight if from > to
  color?: string;
  offsetX?: number;
  offsetY?: number;
}

const {
  label = "You",
  labels,
  pageLabels,
  timeLabels,
  offsetX = 8,
  offsetY = 20,
} = Astro.props;

import { Image } from "astro:assets";
import goose from "src/assets/goose.png";
---

<div id="multiplayer-cursor-label" transition:persist>
  <Image src={goose} alt="Cursor avatar" loading="eager" />
  <span id="cursor-label-text">{label}</span>
</div>

<style lang="scss">
  @use "styles/tokens" as tokens;
  #multiplayer-cursor-label {
    display:flex;
    align-items: center;
    gap: .5rem;
    position: fixed;
    top: 0;
    left: 0;
    padding: 4px 12px 4px 4px;
    border-radius: tokens.radius(full);
    font-size: 14px;
    font-weight: 600;
    white-space: nowrap;
    pointer-events: none;
    will-change: transform;
    opacity: 0;
    filter: blur(0.5rem);
    backdrop-filter: blur(0.5rem);
    transition:
      opacity 0.35s tokens.easing(out),
      filter 0.25s tokens.easing(out);
    z-index: 9999;
    color: var(--color-text);
    background-color: tokens.color-alpha(var(--color-text), 0.15);
    text-shadow: 0 0 3px var(--color-canvas);

    :global([data-cursor-hidden]) & {
      opacity: 0 !important;
      filter: blur(0.5rem) !important;
      pointer-events: none;
    }

    img{
        width: 24px;
        height: auto;
        aspect-ratio: 1;
        border-radius: tokens.radius(full);
        background-color: var(--color-goose);
    }

    span {
      display: inline-block;
      transition: opacity 0.15s, filter 0.15s, width 0.22s tokens.easing(out);
    }

    @include tokens.below(md) {
      display: none;
    }
  }
</style>

<script define:vars={{ offsetX, offsetY, labels, pageLabels, timeLabels }}>
  // ── Animation timing constants ─────────────────────────────────────────────
  // Keep these in sync with the span's CSS transition values in the <style> block.
  const FADE_MS   = 150;  // opacity + filter transition on the span
  const WIDTH_MS  = 220;  // width transition on the span
  const SWAP_DELAY   = 150;  // wait for fade-out before swapping text
  const FADE_IN_DELAY = 70;  // head-start for width before fading text back in

  let mouseX = 0;
  let mouseY = 0;
  let isInside = false;
  let preMusicLabel = null;
  let handlers = null;
  let meHandlers = null;

  function initCursor() {
    const label = document.getElementById("multiplayer-cursor-label");
    const labelText = document.getElementById("cursor-label-text");
    if (!label || !labelText) return;

    // Enforce hidden state on init — overrides any inline style left by transition:persist
    if (document.documentElement.hasAttribute("data-cursor-hidden")) {
      label.style.opacity = "0";
      label.style.filter = "blur(0.5rem)";
    }

    // Picks a random item if passed an array, otherwise uses the string as-is.
    function resolveText(textOrArray) {
      return Array.isArray(textOrArray)
        ? textOrArray[Math.floor(Math.random() * textOrArray.length)]
        : textOrArray;
    }

    // Crossfade helper — blur out, swap text, animate width, blur back in.
    function setLabel(textOrArray) {
      const text = resolveText(textOrArray);

      // Lock current width so the container doesn't jump.
      const fromWidth = labelText.getBoundingClientRect().width;
      labelText.style.width = fromWidth + "px";
      labelText.style.opacity = "0";
      labelText.style.filter = "blur(0.5rem)";

      setTimeout(() => {
        labelText.textContent = text;

        // Measure intrinsic width of the new text.
        labelText.style.width = "auto";
        const toWidth = labelText.getBoundingClientRect().width;

        // Snap back to old width, force reflow, then transition to new width.
        labelText.style.width = fromWidth + "px";
        labelText.offsetWidth; // trigger reflow
        labelText.style.width = toWidth + "px";

        // Give width a head start before fading text back in.
        setTimeout(() => {
          labelText.style.opacity = "";
          labelText.style.filter = "";
        }, FADE_IN_DELAY);

        // Release explicit width once the width transition has finished.
        setTimeout(() => { labelText.style.width = ""; }, WIDTH_MS);
      }, SWAP_DELAY);
    }

    // Merge base labels with any matching time bucket's extras.
    function getActiveLabels() {
      const hour = new Date().getHours();
      const timeBucket = timeLabels?.find(({ from, to }) =>
        from <= to ? hour >= from && hour < to
                   : hour >= from || hour < to
      );

      // Check for a page-specific label rule (startsWith, first match wins)
      const pathname = window.location.pathname;
      const pageMatch = pageLabels?.find(({ path }) => pathname.startsWith(path));

      // Page match replaces base labels; time labels always merge in on top
      const base = pageMatch ? pageMatch.labels : (labels ?? []);
      return timeBucket ? [...base, ...timeBucket.labels] : base;
    }

    // Pick a random label from the active pool on each navigation.
    const pool = getActiveLabels();
    if (pool.length) {
      setLabel(pool[Math.floor(Math.random() * pool.length)]);
    }

    // Remove stale listeners from the previous page before re-attaching.
    if (handlers) {
      document.removeEventListener("mousemove", handlers.move);
      document.removeEventListener("mouseenter", handlers.enter);
      document.removeEventListener("mouseleave", handlers.leave);
      window.removeEventListener("scroll", handlers.scroll);
      window.removeEventListener("spotify:play", handlers.spotifyPlay);
      window.removeEventListener("spotify:pause", handlers.spotifyPause);
    }

    function updatePosition() {
      label.style.transform = `translate(${mouseX + offsetX}px, ${mouseY + offsetY}px)`;
    }

    handlers = {
      move(e) {
        mouseX = e.clientX;
        mouseY = e.clientY;
        updatePosition();
      },
      scroll() {
        updatePosition();
      },
      enter() {
        isInside = true;
        if (document.documentElement.hasAttribute("data-cursor-hidden")) return;
        label.style.opacity = "1";
        label.style.filter = "blur(0)";
      },
      leave() {
        isInside = false;
        label.style.opacity = "0";
        label.style.filter = "blur(.5rem)";
      },
      spotifyPlay() {
        if (!preMusicLabel) preMusicLabel = labelText.textContent;
        setLabel(["Music goose", "Vibing goose", "On repeat goose"]);
      },
      spotifyPause() {
        if (preMusicLabel) {
          setLabel(preMusicLabel);
          preMusicLabel = null;
        }
      },
      spotifyPause() {
        if (preMusicLabel) setLabel(preMusicLabel);
      },
    };

    document.addEventListener("mousemove", handlers.move);
    window.addEventListener("scroll", handlers.scroll, { passive: true });
    document.addEventListener("mouseenter", handlers.enter);
    document.addEventListener("mouseleave", handlers.leave);
    window.addEventListener("spotify:play", handlers.spotifyPlay);
    window.addEventListener("spotify:pause", handlers.spotifyPause);

    // Mouse was already inside the window before navigation — restore visible state.
    if (isInside && !document.documentElement.hasAttribute("data-cursor-hidden")) {
      updatePosition();
      label.style.opacity = "1";
      label.style.filter = "blur(0)";
    }

    // #me hover — swap label while hovering, restore on leave.
    const meEl = document.getElementById("me");
    if (meEl) {
      if (meHandlers) {
        meEl.removeEventListener("mouseenter", meHandlers.enter);
        meEl.removeEventListener("mouseleave", meHandlers.leave);
      }
      const baseLabel = labelText.textContent;
      meHandlers = {
        enter() { setLabel(["Me - Definitely not a goose", "Head goose", "Behind the cursor"]); },
        leave() { setLabel(baseLabel); },
      };
      meEl.addEventListener("mouseenter", meHandlers.enter);
      meEl.addEventListener("mouseleave", meHandlers.leave);
    }
  }

  document.addEventListener("astro:page-load", initCursor);
</script>
