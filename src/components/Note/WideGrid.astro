---
// WideGrid — multi-item wide media grid, breaks out of the note body column.
// See src/components/Note/README.md for full usage docs.
//
// On mobile: always single column.
// ?raw SVG imports are inlined so CSS variables (theming) apply.

interface ImageObject { src: string; [key: string]: unknown }
type Source = string | ImageObject;

interface Props {
  amount: number;
  columns?: number;      // number of columns in the grid, default 2
  srcs?: (Source | undefined | null)[];
  ratio?: string;        // CSS aspect-ratio value applied to all frames, e.g. "3/2", "1/1"
  mobileRatio?: string;  // overrides ratio on all frames at the mobile breakpoint
  style?: string;        // passthrough inline styles on the outer wrapper
}

const { amount, columns = 2, srcs = [], ratio, mobileRatio, style } = Astro.props;

const items = Array.from({ length: amount }, (_, i) => {
  const slotName = `item-${i}`;
  const hasSlot = Astro.slots.has(slotName);
  if (hasSlot) return { useSlot: true, slotName, empty: false, isRawSvg: false, src: null, raw: null };

  const s = srcs[i];
  if (!s) return { useSlot: false, slotName, empty: true, isRawSvg: false, src: null, raw: null };
  const isRawSvg = typeof s === "string" && s.trimStart().startsWith("<svg");
  const src = isRawSvg ? null : (typeof s === "string" ? s : s.src);
  return { useSlot: false, slotName, empty: false, isRawSvg, src, raw: s };
});
---

<div class="note-wide" style={style}>
  <div class="note-wide-grid" style={`--cols: ${columns}`}>
    {items.map(({ useSlot, slotName, empty, isRawSvg, src, raw }) => (
      <div
        class:list={["note-wide__frame", ratio && "note-wide__frame--ratio", mobileRatio && "note-wide__frame--mobile-ratio"]}
        style={[ratio && `--ratio: ${ratio}`, mobileRatio && `--mobile-ratio: ${mobileRatio}`].filter(Boolean).join("; ") || undefined}
      >
        {useSlot
          ? <Fragment set:html={await Astro.slots.render(slotName)} />
          : (!empty && (isRawSvg
              ? <Fragment set:html={raw} />
              : <img src={src!} alt="" loading="lazy" />
            ))
        }
      </div>
    ))}
  </div>
</div>
