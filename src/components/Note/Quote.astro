---
// Quote — pull-quote block for use inside note MDX files.
// Usage:
//   import Quote from "@components/Note/Quote.astro"
//   <Quote quote="..." authorName="..." authorFunction="..." authorImage="https://..." />

import "./Quote.scss";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import Button from "@components/Button/Button.astro";
import { ArrowUpRight } from "@lucide/astro";

interface Props {
  quote: string;
  authorName?: string;
  authorFunction?: string;
  authorImage?: string | ImageMetadata;  // external URL string or Astro imported image
  wide?: boolean;
  url?: string;
  urlLabel?: string;
  size?: "default" | "compact";
  [key: string]: any;
}

const { quote, authorName, authorFunction, authorImage, wide = false, url, urlLabel, size = "default", class: className, ...rest } = Astro.props;

const hasAuthor = authorName || authorFunction || authorImage;
const isImageObject = authorImage && typeof authorImage !== "string";
---

<figure class:list={["quote", wide && "note-wide", size === "compact" && "quote--compact", className]} {...rest}>
  <blockquote>
    <p>{quote}</p>
  </blockquote>

  {(hasAuthor || url) && (
    <div class="quote__footer">
      {hasAuthor && (
        <figcaption>
          {authorImage && (
            isImageObject
              ? <Image src={authorImage as ImageMetadata} alt={authorName ?? ""} />
              : <img src={authorImage as string} alt={authorName ?? ""} />
          )}
          <div class="quote__author">
            {authorName && <span class="quote__name">{authorName}</span>}
            {authorFunction && <span class="quote__function">{authorFunction}</span>}
          </div>
        </figcaption>
      )}
      {url && <Button href={url} title={urlLabel ?? "Learn more"} icon={ArrowUpRight} variant="primary" />}
    </div>
  )}
</figure>
