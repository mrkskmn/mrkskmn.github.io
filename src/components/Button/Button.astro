---
import "./Button.scss";

interface Props {
  href: string;
  title: string;
  target?: "_self" | "_blank" | "_parent" | "_top";
  variant?: "primary" | "ghost";
  icon?: any;
  strokeWidth?: number;
  iconSize?: number;
  size?: "compact" | "large";
  iconPos?: "trailing" | "leading";
  [key: string]: any; // allows data-* and style attributes to pass through
}

const {
  href,
  title,
  target,
  variant = "primary",
  icon: Icon,
  strokeWidth = 1.5,
  iconSize = 20,
  size = "compact",
  iconPos = "trailing",
  ...rest
} = Astro.props;

const isExternal = !href.startsWith("/");
const resolvedTarget = target ?? (isExternal ? "_blank" : "_self");
const rel = resolvedTarget === "_blank" ? "noopener noreferrer" : undefined;
---

<a
  href={href}
  target={resolvedTarget}
  rel={rel}
  class:list={["btn", `btn--${variant}`, `btn--${size}`]}
  {...rest}
>
  <div class="btn__bg"></div>
  {Icon && iconPos === "leading" && <Icon size={iconSize} stroke-width={strokeWidth} />}
  {title}
  {Icon && iconPos === "trailing" && <Icon size={iconSize} stroke-width={strokeWidth} />}
</a>
