---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/Button/Button.astro";
import About from "@components/About/About.astro";
import Quote from "@components/Note/Quote.astro";
import { Image } from "astro:assets";
import { ArrowUpRight } from "@lucide/astro";
import intro from "../assets/intro3.png";
import cursor from "../assets/cursor.svg?raw";
import avatar from "../assets/avatar.svg?raw";
import dots from "../assets/dots.svg?raw";
import * as content from "@consts";
import Logos from "@components/Logos/Logos.astro";

import gh1 from "../assets/gh/gh-example-1.jpg?url";
import yoma1 from "../assets/yoma/yoma-example-2.png?url";
import misc1 from "../assets/misc/rewardly-example-1.jpg?url";
import misc2 from "../assets/misc/supergut-example-1.png?url";
---

<BaseLayout title="Design Leader, Builder & Code Enthusiast">
  <!-- Hero & value proposition -->
  <section>
    <div class="inner inner--hero">
      <h1 class="display" data-animate style="--delay: 0">
        I am
        <span class="pill">
          <span class="svg--cursor" set:html={cursor} />
          <span class="avatar" set:html={avatar} />
          Markus
        </span>

        <br />
        Design leader shaping <br />how design culture <br />thrives at scale.
        {
          !content.cursorVisibleByDefault && (
            <button class="goose" data-umami-event="Click on Goose" />
          )
        }
      </h1>
      <div class="stack stack--h gap--md">
        <Button
          href="https://www.haiilo.com"
          title="Head of UX at Haiilo"
          size="large"
          icon={ArrowUpRight}
          data-animate
          style="--delay: 1"
        />
        <Button
          href="https://www.linkedin.com/in/markuskammin/"
          title={content.linkedin}
          size="large"
          variant="ghost"
          icon={ArrowUpRight}
          data-animate
          style="--delay: 2"
        />
      </div>
    </div>
  </section>

  <!-- Visual breaker -->
  <section class="reset-p-top">
    <div class="inner inner--visual-break" data-animate style="--delay: 2">
      <Image src={intro} height={1200} alt="" loading="eager" />
    </div>
  </section>

  <!-- Core section -->
  <section class="section--core">
    <div class="inner inner--core">
      <div class="stack stack--h">
        <div class="copy stack stack--v">
          <h2 class="display" data-animate-scroll style="--delay: 0">
            10+ years of designing products, leading teams <br />and building
            conditions for great work to happen.
          </h2>
          <p data-animate-scroll style="--delay: 1">
            Right now I'm more into exploring tools and shipping ideas than
            prepping case studies and documenting the past. <br />
            <br />
            If you want to chat about AI workflows and routines, design culture and
            systems, or whatever problem you're trying to solve - reach out.
          </p>
          <div
            class="buttons stack stack--h gap--lg"
            data-animate-scroll
            style="--delay: 2"
          >
            <Button
              href="mailto:hey@markus.design"
              title={content.contact}
              size="large"
              variant="primary"
            />
            <Button
              href="https://www.linkedin.com/in/markuskammin/"
              title={content.linkedin}
              size="large"
              variant="ghost"
              icon={ArrowUpRight}
            />
          </div>
        </div>
        <span
          class="svg--dots"
          set:html={dots}
          data-animate-scroll
          style="--delay: 1"
        />
      </div>
    </div>
  </section>

  <!-- logos -->

  {
    content.activateBrands && (
      <Logos>
        <h2 class="display">Brands I worked with</h2>
        <h4>From my time at Haiilo and Peter Schmidt Group</h4>
      </Logos>
    )
  }

  <!-- work grid -->
  <section>
    <div class="inner inner--work">
      <div class="work__grid">
        <div class="work__item" style={`background-image: url(${gh1})`}></div>
        <div class="work__item" style={`background-image: url(${yoma1})`}></div>
        <div class="work__item" style={`background-image: url(${misc1})`}></div>
        <div class="work__item" style={`background-image: url(${misc2})`}></div>
      </div>
    </div>
  </section>

  <!-- testimonials -->
  <section>
    <div class="inner inner--testimonials">
      <div class="stack stack--v gap--lg">
        <h2 class="display">In others' words.</h2>
        <h4>Some kind words from people I've worked with.</h4>
      </div>
      <div class="stack stack--v gap--xl">
        <Quote
          quote="Markus is one of the most talented UX designers and leaders I’ve worked with. He combines a natural, effective leadership style with a hands-on passion for solving complex UX challenges, delivering creative solutions at remarkable speed […]"
          authorName="Gary Bennion"
          authorFunction="Former CPTO, Haiilo"
          authorImage="https://media.licdn.com/dms/image/v2/D4E03AQEEixJgeTrsNQ/profile-displayphoto-scale_200_200/B4EZt_.PLkGQAY-/0/1767378582168?e=2147483647&v=beta&t=lkDACtrxjRwjns_XIAi93RH78S_TTXsH1Qf7Q-N3zd8"
          url="https://www.linkedin.com/in/markuskammin/details/recommendations"
          urlLabel="Read full recommendation"
          size="compact"
          class="reset--m"
        />
        <Quote
          quote="Very simple: Markus is the best product & UI designer I've worked with. He is the mastermind behind Haiilo's strong position and USP in UI/UX which is widely appreciated by our customers. He's not only an exceptional designer. He also has great understanding for product and market […]"
          authorName="Jan Marquardt"
          authorFunction="Founder & Former CEO, Haiilo"
          authorImage="https://media.licdn.com/dms/image/v2/D4E03AQGgNeV0adjtYg/profile-displayphoto-shrink_200_200/profile-displayphoto-shrink_200_200/0/1731570268496?e=2147483647&v=beta&t=1NLbzpVpHMylv_lEnn-jwrlaOI5ulti03x1Dda63JyE"
          url="https://www.linkedin.com/in/markuskammin/details/recommendations"
          urlLabel="Read full recommendation"
          size="compact"
          class="reset--m"
        />

        <Quote
          quote="Without Markus, I'm not sure where Haiilo would be today as a company. He's unassuming, always willing to listen, and continues to develop his skills even under high pressure and heavy workloads. […]"
          authorName="Florian Lindenau"
          authorFunction="Former VP BI & Operations, Haiilo"
          authorImage="https://media.licdn.com/dms/image/v2/C5603AQHRybhQsp5AZQ/profile-displayphoto-shrink_800_800/profile-displayphoto-shrink_800_800/0/1553163535847?e=1779321600&v=beta&t=wFIO-oU8ruqu56-SlFWYOoUYnYGnsvm3TU8rg7g6G5U"
          url="https://www.linkedin.com/in/markuskammin/details/recommendations"
          urlLabel="Read full recommendation"
          size="compact"
          class="reset--m"
        />
      </div>
    </div>
  </section>

  <!-- about me -->
  <About />


</BaseLayout>

<script>
  let clicks = 0;
  let timer: ReturnType<typeof setTimeout>;

  function initThemeEasterEgg() {
    const avatar = document.querySelector(".avatar");
    if (!avatar) return;

    clicks = 0; // reset count on each page load

    avatar.addEventListener("pointerdown", (e) => {
      e.preventDefault();
      clicks++;
      clearTimeout(timer);
      timer = setTimeout(() => {
        clicks = 0;
      }, 2000);

      if (clicks >= 3) {
        clicks = 0;
        const html = document.documentElement;
        const next = html.dataset.theme === "dark" ? "light" : "dark";
        html.classList.add("is-theme-transitioning");
        html.dataset.theme = next;
        localStorage.setItem("theme", next);
        setTimeout(() => html.classList.remove("is-theme-transitioning"), 300);
      }
    });
  }

  // Re-attach on every page load since view transitions replace the DOM
  document.addEventListener("astro:page-load", initThemeEasterEgg);

  function initGooseToggle() {
    const btn = document.querySelector(".goose");
    if (!btn) return;

    // Default is hidden — show cursor only if user previously activated it
    const saved = localStorage.getItem("cursor-hidden");
    const shouldHide = saved !== "0";
    document.documentElement.toggleAttribute("data-cursor-hidden", shouldHide);

    btn.addEventListener("click", () => {
      const hidden =
        document.documentElement.toggleAttribute("data-cursor-hidden");
      localStorage.setItem("cursor-hidden", hidden ? "1" : "0");

      const label = document.getElementById("multiplayer-cursor-label");
      if (!label) return;
      if (hidden) {
        label.style.opacity = "0";
        label.style.filter = "blur(0.5rem)";
      } else {
        label.style.opacity = "1";
        label.style.filter = "blur(0)";
      }
    });
  }

  document.addEventListener("astro:page-load", initGooseToggle);
</script>
