---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/Button/Button.astro";
import About from "@components/About/About.astro";
import { Image } from "astro:assets";
import { ArrowUpRight } from "@lucide/astro";
import blueNoise from "../assets/bluenoise.jpg";
import cursor from "../assets/cursor.svg?raw";
import avatar from "../assets/avatar.svg?raw";
import dots from "../assets/dots.svg?raw";
---

<BaseLayout title="Start">
  <!-- Hero & value proposition -->
  <section>
    <div class="inner inner--hero">
      <h1 class="display" data-animate style="--delay: 0">
        I am
        <span class="pill">
          <span class="svg--cursor" set:html={cursor} />
          <span class="avatar" set:html={avatar} />
          Markus
        </span>

        <br />
        Design leader shaping <br />how design culture <br />thrives at scale.
      </h1>
      <div class="stack stack--h gap--md">
        <Button
          href="https://www.haiilo.com"
          title="head of ux at haiilo"
          size="large"
          icon={ArrowUpRight}
          data-animate
          style="--delay: 1"
        />
        <Button
          href="https://www.linkedin.com/in/markuskammin/"
          title="LinkedIn"
          size="large"
          variant="ghost"
          icon={ArrowUpRight}
          data-animate
          style="--delay: 2"
        />
      </div>
    </div>
  </section>

  <!-- Visual breaker -->
  <section>
    <div class="inner inner--visual-break" data-animate style="--delay: 2">
      <Image src={blueNoise} height={800} alt="" />
    </div>
  </section>

  <!-- Core section -->
  <section class="section--core">
    <div class="inner inner--core">
      <div class="stack stack--h">
        <div class="copy stack stack--v">
          <h2 class="display" data-animate-scroll style="--delay: 0">
            10+ years designing products, leading teams, and figuring out how to
            make complex things simple.
          </h2>
          <p class="lead" data-animate-scroll style="--delay: 1">
            Right now I'm more into building tools and shipping ideas than
            prepping case studies and documenting the past. <br />
            <br />
            If you want to chat about AI tools and workflows, design culture and systems,
            or whatever problem you're trying to solve - reach out.
          </p>
          <div
            class="buttons stack stack--h gap--lg"
            data-animate-scroll
            style="--delay: 2"
          >
            <Button
              href="mailto:hey@markus.design"
              title="hey@markus.design"
              size="large"
              variant="primary"
            />
            <Button
              href="https://www.linkedin.com/in/markuskammin/"
              title="LinkedIn"
              size="large"
              variant="ghost"
              icon={ArrowUpRight}
            />
          </div>
        </div>
        <span
          class="svg--dots"
          set:html={dots}
          data-animate-scroll
          style="--delay: 1"
        />
      </div>
    </div>
  </section>

  <!-- work grid -->
  <section>
    <div class="inner inner--work">
      <div class="work__grid">
        <div class="work__item"></div>
        <div class="work__item"></div>
        <div class="work__item"></div>
        <div class="work__item"></div>
      </div>
    </div>
  </section>

  <!-- about me -->
  <About />

</BaseLayout>
