---
import "../styles/notes.scss";
import BaseLayout from "@layouts/BaseLayout.astro";
import About from "@components/About/About.astro";
import { getCollection } from "astro:content";

const notes = await getCollection("notes");
const sorted = notes.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
---

<BaseLayout title="Notes">
  <!-- Hero -->
  <section>
    <div class="inner inner--hero">
      <h1 class="display" data-animate style="--delay: 0">
        A collection of thoughts,<br />ideas and writings
      </h1>
    </div>
  </section>

  <!-- Card grid -->
  <section>
    <div class="inner notes-grid">
      {sorted.map((note, i) => (
        <a
          href={`/notes/${note.id}`}
          class="note-card"
          data-animate
          style={`--delay: ${i + 2}`}
        >
          <div class="note-card__image">
            <img src={note.data.image} alt={note.data.title} />
          </div>
          <div class="note-card__content">
            <h2 class="display">{note.data.title}</h2>
            {note.data.subline && <p class="note-card__subline">{note.data.subline}</p>}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- About -->
  <About />
</BaseLayout>
