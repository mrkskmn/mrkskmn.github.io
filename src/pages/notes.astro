---
import "../styles/notes.scss";
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/Button/Button.astro";
import About from "@components/About/About.astro";
import bluenoise from "../assets/bluenoise.jpg?url";
import orangenoise from "../assets/orangenoise.jpg?url";
import noise1 from "../assets/noise-1.jpg?url";
---

<BaseLayout title="Notes">
  <!-- Hero -->
  <section>
    <div class="inner inner--hero">
      <h1 class="display" data-animate style="--delay: 0">
        A collection of thoughts,<br />ideas and writings
      </h1>
    </div>
  </section>

  <!-- Cards + text list — same container, same width -->
  <section>
    <div class="inner notes-grid">
      <article class="note-card" data-animate style="--delay: 3">
        <div
          class="note-card__image"
          style={`background-image: url("${bluenoise}");`}
        >
        </div>

        <div class="note-card__content">
          <h2 class="display">Building design at Haiilo</h2>
          <p class="descr">I am the description of this note</p>
        </div>
      </article>

      <article class="note-card" data-animate style="--delay: 4">
        <div
          class="note-card__image"
          style={`background-image: url("${noise1}");`}
        >
        </div>
        <div class="note-card__content">
          <h2 class="display">
            Design systems in the area of MCP and coding agents.
          </h2>
        </div>
      </article>

      <article class="note-card" data-animate style="--delay: 5">
        <div
          class="note-card__image"
          style={`background-image: url("${orangenoise}");`}
        >
        </div>
        <div class="note-card__content">
          <h2 class="display">
            Design systems in the area of MCP and coding agents.
          </h2>
        </div>
      </article>

      <article class="note-card" data-animate style="--delay: 6">
        <div
          class="note-card__image"
          style={`background-image: url("${noise1}");`}
        >
        </div>
        <div class="note-card__content">
          <h2 class="display">
            Design systems in the area of MCP and coding agents.
          </h2>
        </div>
      </article>

      <!-- col 3, row 2 -->
      <!-- <aside class="note-card note-card--tip" data-animate-scroll style="--delay: 2">
        <span class="note-card__label">tip</span>
        <p>
          build out important ui docs as figma lib. your designers can quickly
          pull in knowledge directly to their canvas.
        </p>
      </aside> -->

      <!-- Text-only note entries -->
      <!-- <div class="notes-list">
        <a href="#" class="notes-list__item" data-animate-scroll style="--delay: 0">
          <h2 class="display">Note title</h2>
          <p>A reflection on my last 8+ years in the b2b saas space.</p>
        </a>
        <a href="#" class="notes-list__item" data-animate-scroll style="--delay: 1">
          <h2 class="display">Note title</h2>
          <p>A reflection on my last 8+ years in the b2b saas space.</p>
        </a>
      </div> -->
    </div>
  </section>

  <!-- About -->
  <About />
</BaseLayout>
